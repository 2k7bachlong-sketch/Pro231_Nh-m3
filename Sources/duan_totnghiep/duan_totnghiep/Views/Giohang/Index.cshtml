@model List<duan_totnghiep.Models.Giohang>
@{
    Layout = "_LayoutAdmin";
}
@{
    ViewData["Title"] = "Giỏ hàng";
}
<style>

    body {
        background-color: #f5f5f5;
        font-family: Arial, sans-serif;
    }

    .title {
        text-align: center;
        margin-top: 40px;
        margin-bottom: 40px;
        font-size: 40px;
        font-weight: bold;
    }

    .cart-container {
        width: 90%;
        margin: auto;
        background: white;
        border-radius: 15px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #333;
        color: white;
        padding: 20px;
        font-size: 18px;
    }

    td {
        padding: 20px;
        text-align: center;
        border-bottom: 1px solid #ddd;
    }

        td img {
            width: 100px;
            height: 100px;
            object-fit: cover;
        }

    .quantity a {
        text-decoration: none;
        background: black;
        color: white;
        padding: 5px 12px;
        border-radius: 5px;
        margin: 0 10px;
        font-size: 18px;
    }

        .quantity a:hover {
            background: #555;
        }

    .btn-delete {
        background: red;
        color: white;
        padding: 10px 15px;
        border-radius: 8px;
        text-decoration: none;
    }

        .btn-delete:hover {
            background: darkred;
        }

    .btn-clear {
        display: inline-block;
        margin: 30px;
        background: black;
        color: white;
        padding: 12px 20px;
        border-radius: 10px;
        text-decoration: none;
    }

        .btn-clear:hover {
            background: #444;
        }

    .empty-cart {
        color: red;
        font-size: 28px;
        padding: 50px;
        text-align: center;
    }

</style>

<h1 class="title">GIỎ HÀNG</h1>

<div class="cart-container">

    <table>

        <tr>
            <th>Hình ảnh</th>
            <th>Tên sản phẩm</th>
            <th>Đơn giá</th>
            <th>Số lượng</th>
            <th>Thành tiền</th>
            <th>Thao tác</th>
        </tr>

        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="6" class="empty-cart">
                    🛒 Giỏ hàng trống
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>

                    <td>
                        <img src="~/images/@item.Sanpham.Hinhanh" />
                    </td>

                    <td>
                        @item.Sanpham.Tensp
                    </td>

                    <td>
                        @string.Format("{0:N0}", item.Sanpham.Gia) đ
                    </td>

                    <td class="quantity">

                        <a asp-action="Giam"
                           asp-route-id="@item.Magh">
                            -
                        </a>

                        @item.Soluong

                        <a asp-action="Tang"
                           asp-route-id="@item.Magh">
                            +
                        </a>

                    </td>

                    <td>
                        @string.Format("{0:N0}",
                        item.Soluong* item.Sanpham.Gia) đ
            </td>

            <td>

                <a asp-action="Xoa"
                   asp-route-id="@item.Magh"
                   class="btn-delete">
                    Xóa
                </a>

            </td>

        </tr>
                }
        }

    </table>

    <a asp-action="XoaTatCa"
       class="btn-clear">
        Xóa toàn bộ giỏ hàng
    </a>

</div>