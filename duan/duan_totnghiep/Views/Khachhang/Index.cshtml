@model IEnumerable<duan_totnghiep.Models.Khachhang>

@{
    Layout = "_Layout";
}

<div class="crud-container">

    <div class="crud-header">
        <h2>Quản lý khách hàng</h2>

        <a asp-action="Them" class="btn btn-add">
            + Thêm khách hàng
        </a>
    </div>

    <table class="crud-table">

        <thead>
            <tr>
                <th>Mã KH</th>
                <th>Họ tên</th>
                <th>SĐT</th>
                <th>Email</th>
                <th>Địa chỉ</th>
                <th width="250">Chức năng</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Makh</td>

                    <td>@item.Hoten</td>

                    <td>@item.Sdt</td>

                    <td>@item.Email</td>

                    <td>@item.Diachi</td>

                    <td>

                        <a asp-action="ChiTiet"
                           asp-route-id="@item.Makh"
                           class="btn btn-detail">
                            Chi tiết
                        </a>

                        <a asp-action="Sua"
                           asp-route-id="@item.Makh"
                           class="btn btn-edit">
                            Sửa
                        </a>

                        <a asp-action="Xoa"
                           asp-route-id="@item.Makh"
                           class="btn btn-delete">
                            Xóa
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>