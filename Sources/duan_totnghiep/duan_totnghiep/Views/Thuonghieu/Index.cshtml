@model IEnumerable<duan_totnghiep.Models.Thuonghieu>
@{
    Layout = "_Layout";
}

<div class="crud-container">

    <div class="crud-header">
        <h2>Quản lý thương hiệu</h2>

        <a asp-action="Them" class="btn btn-add">
            + Thêm thương hiệu
        </a>
    </div>

    <table class="crud-table">

        <thead>
            <tr>
                <th>Mã</th>
                <th>Tên thương hiệu</th>
                <th>Mô tả</th>
                <th>Thao tác</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Math</td>

                    <td>@item.Tenth</td>

                    <td>@item.Mota</td>

                    <td>

                        <a asp-action="Sua"
                           asp-route-id="@item.Math"
                           class="btn btn-brand-edit">
                            Sửa
                        </a>

                        <a asp-action="Chitiet"
                           asp-route-id="@item.Math"
                           class="btn btn-brand-detail">
                            Chi tiết
                        </a>

                        <a asp-action="Xoa"
                           asp-route-id="@item.Math"
                           class="btn btn-brand-delete">
                            Xóa
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>
}
