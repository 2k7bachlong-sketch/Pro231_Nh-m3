@model duan_totnghiep.Models.Sanpham
@{
    Layout = "_Layout";
}
<div class="form-container">

    <h2>SỬA SẢN PHẨM</h2>

    <form asp-action="Sua" method="post">

        <input type="hidden" asp-for="Masp" />

        <div class="form-group">
            <label>Tên sản phẩm</label>
            <input asp-for="Tensp" class="form-control">
        </div>

        <div class="form-group">
            <label>Giá</label>
            <input asp-for="Gia" class="form-control">
        </div>

        <div class="form-group">
            <label>Hình ảnh</label>
            <input type="file" name="fileAnh" class="form-control">
        </div>

        <div class="form-group">
            <label>Số lượng</label>
            <input asp-for="Soluongton" class="form-control">
        </div>

        <div class="form-group">
            <label>Danh mục</label>

            <select asp-for="Madm"
                    asp-items="ViewBag.Madm"
                    class="form-control">
            </select>
        </div>

        <div class="form-group">
            <label>Thương hiệu</label>

            <select asp-for="Math"
                    asp-items="ViewBag.Math"
                    class="form-control">
            </select>
        </div>
        <div class="form-group">
            <label>Khuyến mãi</label>

            <select asp-for="Makm"
                    asp-items="ViewBag.Makm"
                    class="form-control">

                <option value="">-- Không áp dụng --</option>

            </select>
        </div>

        <button type="submit" class="btn btn-edit">
            Cập nhật
        </button>

        <a asp-action="Index"
           class="btn btn-cancel">
            Quay lại
        </a>

    </form>

</div>