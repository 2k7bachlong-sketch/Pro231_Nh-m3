@model duan_totnghiep.Models.Danhmuc
@{
    Layout = "_Layout";
}
<h2>Thêm danh mục</h2>

<form asp-action="Them" method="post">
    <div class="form-group">
        <label>Tên danh mục</label>
        <input asp-for="Tendm" class="form-control" />
    </div>

    <div class="form-group">
        <label>Mô tả</label>
        <input asp-for="Mota" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success mt-2">Lưu</button>
</form>