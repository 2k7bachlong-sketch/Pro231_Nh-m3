@model duan_totnghiep.Models.Thuonghieu
@{
    Layout = "_Layout";
}
<h2>Sửa thương hiệu</h2>

<form asp-action="Sua">

    <input type="hidden" asp-for="Math" />

    <div class="form-group">
        <label>Tên thương hiệu</label>
        <input asp-for="Tenth" class="form-control" />
    </div>

    <div class="form-group">
        <label>Mô tả</label>
        <input asp-for="Mota" class="form-control" />
    </div>

    <button class="btn btn-edit">
        Cập nhật
    </button>

</form>
