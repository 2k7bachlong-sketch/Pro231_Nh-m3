@model duan_totnghiep.Models.Thuonghieu
@{
    Layout = "_Layout";
}
<h2>Xóa thương hiệu</h2>

<h4>Bạn có chắc muốn xóa?</h4>

<p>@Model.Tenth</p>

<form asp-action="Xoa">

    <input asp-for="Math" type="hidden" />

    <button class="btn btn-delete">
        Xóa
    </button>

    <a asp-action="Index"
       class="btn btn-cancel">
        Hủy
    </a>

</form>
