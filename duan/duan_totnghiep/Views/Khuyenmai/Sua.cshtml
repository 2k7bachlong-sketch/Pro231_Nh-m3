@model duan_totnghiep.Models.Khuyenmai

@{
    Layout = "_Layout";
}

<div class="form-container">

    <h2>Sửa khuyến mãi</h2>

    <form asp-action="Sua">

        <input type="hidden" asp-for="Makm" />

        <div class="form-group">
            <label>Tên khuyến mãi</label>
            <input asp-for="Tenkm" class="form-control" />
        </div>

        <div class="form-group">
            <label>Phần trăm giảm</label>
            <input asp-for="Phantramgiam" class="form-control" />
        </div>

        <div class="form-group">
            <label>Ngày bắt đầu</label>
            <input asp-for="Ngaybatdau" type="date" class="form-control" />
        </div>

        <div class="form-group">
            <label>Ngày kết thúc</label>
            <input asp-for="Ngayketthuc" type="date" class="form-control" />
        </div>

        <div class="form-group">
            <label>Trạng thái</label>
            <input asp-for="Trangthai" class="form-control" />
        </div>

        <button class="btn btn-edit">
            Lưu
        </button>

        <a asp-action="Index" class="btn btn-cancel">
            Quay lại
        </a>

    </form>

</div>
