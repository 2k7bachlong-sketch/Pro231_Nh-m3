@{
    ViewData["Title"] = "Trang chủ";
}
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>StarPard Shop</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #a9a9a9;
            font-family: Arial, sans-serif;
        }

        /* HEADER */

        .header {
            height: 90px;
            background: gray;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 40px;
        }

        .logo img {
            width: 100px;
            height: 100px;
        }

        .search-box {
            width: 430px;
            height: 35px;
            background: white;
            border: 2px solid black;
            border-radius: 30px;
            display: flex;
            overflow: hidden;
        }

            .search-box input {
                flex: 1;
                border: none;
                outline: none;
                padding-left: 20px;
                font-size: 16px;
            }

            .search-box button {
                width: 60px;
                border: none;
                background: white;
                font-size: 18px;
                cursor: pointer;
            }

        .right-menu {
            display: flex;
            align-items: center;
            gap: 25px;
        }

            .right-menu i {
                font-size: 40px;
                color: black;
            }

        .btn-dangki {
            background: black;
            color: white;
            padding: 12px 25px;
            border-radius: 30px;
            text-decoration: none;
            font-size: 22px;
        }

        /* DANH MỤC */

        .category {
            height: 70px;
            background: #e5e5e5;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 70px;
            font-size: 18px;
            font-weight: bold;
        }

            .category a {
                text-decoration: none;
                color: black;
            }

        /* SẢN PHẨM */

        .products {
            margin-top: 50px;
            display: flex;
            justify-content: center;
            gap: 80px;
        }

        .card {
            width: 220px;
            height: 270px;
            background: white;
            border: 5px solid black;
            border-radius: 20px;
            text-align: center;
            padding: 15px;
        }

            .card img {
                width: 120px;
                height: 120px;
                object-fit: cover;
            }

            .card h3 {
                margin-top: 10px;
                font-size: 15px;
            }

        .price {
            margin-top: 25px;
            font-size: 22px;
        }

    </style>
</head>
<body>

    <!-- HEADER -->

    <div class="header">

        <div class="logo">
            <img src="~/images/starlogo.png" />
        </div>

        <div class="search-box">
            <input type="text" placeholder="Tìm kiếm..." />
            <button>
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
        </div>

        <div class="right-menu">

            <a href="#">
                <i class="fa-solid fa-cart-shopping"></i>
            </a>

            <a href="#">
                <i class="fa-solid fa-circle-user"></i>
            </a>

            <a href="/DangKy/Index" class="btn-dangki">
                Đăng kí
            </a>

        </div>

    </div>

    <!-- DANH MỤC -->

    <div class="category">

        <a href="#">Giày đá bóng</a>

        <a href="#">Giày chạy bộ</a>

        <a href="#">Giày da</a>

        <a href="#">Giày cao gót</a>

    </div>

    <!-- SẢN PHẨM -->

    <div class="products">

        <div class="card">
            <img src="~/images/shoes1.jpg" />
            <h3>Giày Grand sport</h3>
            <div class="price">720.000đ</div>
        </div>

        <div class="card">
            <img src="~/images/shoes2.jpg" />
            <h3>Giày da nữ</h3>
            <div class="price">250.000đ</div>
        </div>

        <div class="card">
            <img src="~/images/shoes3.webp" />
            <h3>Giày Convert chuck taylor</h3>
            <div class="price">320.000đ</div>
        </div>

    </div>

</body>
</html>
