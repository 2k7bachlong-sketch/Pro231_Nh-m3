@model duan_totnghiep.Models.Taikhoan
@{
    Layout = null;
    ViewData["Title"] = "Đăng ký";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đăng ký</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #eee;
            font-family: Arial;
        }

        .header {
            width: 100%;
            height: 90px;
            background: gray;
            display: flex;
            align-items: center;
            justify-content: center; /* bỏ space-around */
            position: relative;
        }

        .logo {
            width: 100px;
            height: 100px;
            position: absolute;
            left: 20px; 
        }

        .search-box {
            width: 100%;
            display: flex;
            justify-content: center;
        }

            .search-box input {
                width: 500px;
                height: 40px;
                border-radius: 30px;
                border: 1px solid black;
                padding-left: 20px;
            }

        .container {
            display: flex;
            justify-content: center;
            margin-top: 60px;
            gap: 120px;
        }

        .left {
            text-align: center;
        }

            .left img {
                width: 300px;
            }

            .left h1 {
                margin-top: 20px;
            }

        .register-box {
            width: 360px;
            background: #ccc;
            padding: 40px;
            border-radius: 30px;
        }

        .title {
            background: black;
            color: white;
            width: 160px;
            margin: auto;
            padding: 15px;
            border-radius: 30px;
            text-align: center;
            margin-bottom: 50px;
        }

        .form-group {
            margin-bottom: 25px;
        }

            .form-group input {
                width: 100%;
                height: 45px;
                border: none;
                border-radius: 10px;
                padding-left: 15px;
                font-size: 18px;
            }

        .btnDangKy {
            width: 100%;
            height: 45px;
            background: black;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 20px;
            cursor: pointer;
        }

        .input-role {
            width: 100%;
            height: 45px;
            border: none;
            border-radius: 10px;
            padding-left: 15px;
            font-size: 18px;
            margin-bottom: 25px;
        }
        .btnDangKy:hover {
            background: #333;
        }

        .error {
            color: red;
            text-align: center;
            margin-bottom: 15px;
        }
    </style>
</head>

<body>
    @if (ViewBag.Loi != null)
    {
        <div style="color:red">
            @ViewBag.Loi
        </div>
    }
    <div class="header">

        <img src="~/images/starlogo.png" class="logo" />

        <div class="search-box">
            <input type="text" placeholder="Tìm kiếm..." />
        </div>

    </div>

    <div class="container">

        <div class="left">
            <img src="~/images/starlogo.png" />
            <h1>Shop bán giày chính hãng</h1>
        </div>

        <div class="register-box">

            <h2 class="title">Đăng ký</h2>

            @if (ViewBag.Loi != null)
            {
                <p class="error">@ViewBag.Loi</p>
            }

            <form asp-action="DangKy" method="post">

                <div class="form-group">
                    <input type="text"
                           name="TenDangNhap"
                           placeholder="Tên đăng tài khoản" />
                </div>

                <div class="form-group">
                    <input type="text"
                           name="SoDienThoai"
                           placeholder="SĐT" />
                </div>

                <div class="form-group">
                    <input type="password"
                           name="MatKhau"
                           placeholder="Mật khẩu" />
                </div>
                <div class="form-group">
                    <input type="password"
                           name="NhapLaiMatKhau"
                           placeholder="Nhập lại mật khẩu" />
                </div>

                <button type="submit" class="btnDangKy">
                    Đăng ký
                </button>

            </form>

        </div>

    </div>

</body>
</html>
