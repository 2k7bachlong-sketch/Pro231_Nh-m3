@model IEnumerable<duan_totnghiep.Models.Donhang>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "_Layout";
}

<div class="crud-container">

    <div class="crud-header">
        <h2>Quản lý đơn hàng</h2>

        <a asp-action="Them" class="btn btn-add">
            + Thêm đơn hàng
        </a>
    </div>

    <table class="crud-table">

        <thead>
            <tr>
                <th>Mã</th>
                <th>Khách hàng</th>
                <th>Nhân viên</th>
                <th>Ngày đặt</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Chức năng</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Madh</td>
                    <td>@item.Khachhang?.Hoten</td>
                    <td>@item.Nhanvien?.Hoten</td>
                    <td>@item.Ngaydat?.ToString("dd/MM/yyyy")</td>
                    <td>@item.Tongtien.ToString("N0") VNĐ</td>
                    <td>@item.Trangthai</td>

                    <td>
                        <a asp-action="Sua" asp-route-id="@item.Madh" class="btn btn-edit">Sửa</a>

                        <a asp-action="Chitiet" asp-route-id="@item.Madh" class="btn btn-detail">Chi tiết</a>

                        <a asp-action="Xoa" asp-route-id="@item.Madh" class="btn btn-delete">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>

    </table>

</div>