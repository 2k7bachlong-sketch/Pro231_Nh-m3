@model duan_totnghiep.Models.Taikhoan
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập StarPard</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #f5f5f5;
            font-family: Arial;
        }

        .header {
            height: 90px;
            background: gray;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
        }

        .logo {
            width: 100px;
            height: 100px;
        }

        .search {
            width: 450px;
            height: 40px;
            border-radius: 30px;
            border: 1px solid black;
            padding-left: 15px;
        }

        .container {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 120px;
            margin-top: 50px;
        }

        .left {
            text-align: center;
        }

            .left img {
                width: 300px;
            }

            .left h2 {
                margin-top: 20px;
                font-size: 40px;
            }

        .right {
            width: 380px;
            height: 450px;
            background: #cfcfcf;
            border-radius: 25px;
            padding: 30px;
        }

        .title {
            background: black;
            color: white;
            width: 180px;
            text-align: center;
            padding: 12px;
            border-radius: 30px;
            margin: auto;
            font-size: 30px;
        }

        .input-box {
            width: 100%;
            height: 50px;
            margin-top: 40px;
            border: none;
            border-radius: 15px;
            padding-left: 15px;
            font-size: 18px;
        }

        .btn {
            width: 100%;
            height: 50px;
            margin-top: 30px;
            border: none;
            border-radius: 15px;
            background: black;
            color: white;
            font-size: 20px;
            cursor: pointer;
        }

            .btn:hover {
                background: #333;
            }
    </style>
</head>

<body>

    <div class="header">
        <img src="/images/starlogo.png" class="logo" />

        <input type="text" class="search" placeholder="Tìm kiếm..." />

        <div></div>
    </div>

    <div class="container">

        <div class="left">
            <img src="/images/starlogo.png" />
            <h2>Shop bán giày uy tín chính hãng</h2>
        </div>

        <div class="right">

            <div class="title">
                Đăng nhập
            </div>

            <form asp-action="Index" method="post">

                <input type="text"
                       name="Tendangnhap"
                       class="input-box"
                       placeholder="Tên đăng nhập" />

                <input type="password"
                       name="Matkhau"
                       class="input-box"
                       placeholder="Mật khẩu" />


                <button type="submit" class="btn">
                    Đăng nhập
                </button>

            </form>

        </div>

    </div>

</body>
</html>